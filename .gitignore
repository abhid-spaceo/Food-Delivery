# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js
/.next/
/out/
/build

# testing — Vitest / Playwright
/coverage
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# env files — never commit real secrets; keep the template
.env*
!.env.example

# vercel
.vercel

# claude code worktrees (parallel sessions live here)
.claude/worktrees/

# typescript
*.tsbuildinfo
next-env.d.ts

# misc
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
