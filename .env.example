# =============================================================================
# Environment template — copy to .env and fill in real values.
#   cp .env.example .env
# .env is gitignored; never commit real secrets. Only this template is tracked.
# =============================================================================

# --- Database (Prisma + PostgreSQL) -----------------------------------------
# Read by lib/db.ts, prisma/schema.prisma, and prisma/seed.ts.
# Local Postgres example below; in production use your Vercel Postgres / Neon URL.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/food_delivery?schema=public"

# --- Auth.js (NextAuth v5) --------------------------------------------------
# Signs/encrypts the session JWT. Auth.js reads AUTH_SECRET automatically.
# Generate one with:  npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""

# --- Stripe (TEST MODE ONLY) ------------------------------------------------
# Secret key: read by lib/stripe.ts; used to create Checkout sessions + verify webhooks.
# Use a test-mode key only — it starts with sk_test_...
STRIPE_SECRET_KEY=

# Webhook signing secret: verifies incoming events at POST /api/stripe/webhook.
# Get it from `stripe listen --forward-to localhost:3000/api/stripe/webhook` (local)
# or from the Stripe Dashboard → Webhooks (production).
STRIPE_WEBHOOK_SECRET=

# Absolute base URL for Stripe redirect URLs (success/cancel after checkout).
# In production set this to your Vercel deployment URL (https://your-app.vercel.app).
NEXT_PUBLIC_APP_URL=http://localhost:3000
